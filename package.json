{
  "name": "stalwart-jmap",
  "version": "0.3.1",
  "type": "module",
  "description": "OpenClaw plugin that adds typed Stalwart JMAP tools for email, calendar, and contacts.",
  "files": [
    "dist/index.js",
    "skills",
    "openclaw.plugin.json",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/index.test.js"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openclaw": "2026.3.24",
    "typescript": "^6.0.2"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "stalwart-jmap",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.24"
    },
    "release": {
      "publishToNpm": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
